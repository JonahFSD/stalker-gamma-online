void CALifeUpdateManager::set_mp_client_mode(bool value)
{
	m_mp_client_mode = value;
	if (value)
		Msg("* [GAMMA MP] A-Life client mode ENABLED - local simulation suppressed");
	else
		Msg("* [GAMMA MP] A-Life client mode DISABLED - local simulation active");
}

