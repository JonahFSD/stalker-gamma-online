// GAMMA MP: A-Life suppression for multiplayer clients
void set_mp_client_mode(CALifeSimulator* self, bool value)
{
	self->set_mp_client_mode(value);
}

bool get_mp_client_mode(CALifeSimulator* self)
{
	return self->mp_client_mode();
}


