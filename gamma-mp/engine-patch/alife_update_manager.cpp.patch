void CALifeUpdateManager::shedule_Update(u32 dt)
{
	ISheduled::shedule_Update(dt);

	if (!initialized())
		return;

	// GAMMA MP: skip scheduled A-Life updates on multiplayer clients
	if (m_mp_client_mode)
		return;


